# Sanity 연결값. 실제 값은 .env.local에 넣는다(커밋 금지).
# projectId·dataset은 공개값, 토큰은 시크릿.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# 읽기 토큰(서버 전용, 초안/비공개 조회용). 공개 데이터셋만 쓰면 불필요.
SANITY_API_READ_TOKEN=

# 사이트 절대 URL(canonical·OG용)
NEXT_PUBLIC_SITE_URL=https://ruehan.dev

# on-demand revalidation API secret. deploy hook 등에서 호출 시 검증. 길고 추측 어려운 문자열.
REVALIDATE_SECRET=
